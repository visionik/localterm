{
  "name": "localterm-server",
  "version": "0.0.1",
  "description": "PTY-backed HTTP/WebSocket server that powers localterm — Hono + node-pty + headless xterm.",
  "keywords": [
    "hono",
    "localterm",
    "node-pty",
    "pty",
    "terminal",
    "websocket",
    "xterm"
  ],
  "homepage": "https://github.com/aidenybai/localterm#readme",
  "bugs": {
    "url": "https://github.com/aidenybai/localterm/issues"
  },
  "license": "MIT",
  "author": "Aiden Bai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aidenybai/localterm.git",
    "directory": "packages/server"
  },
  "files": [
    "dist"
  ],
  "os": [
    "darwin",
    "linux"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vp test --run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/node-ws": "^1.1.1",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/headless": "^5.5.0",
    "hono": "^4.6.13",
    "nanoid": "^5.0.9",
    "node-pty": "^1.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.9.3",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.19"
  },
  "engines": {
    "node": ">=22"
  }
}
